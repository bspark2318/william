# Frontend environment — copy to .env.local and fill in.

# Public backend URL used for non-admin reads (issues feed, etc.)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Admin proxy config. Server-side only — NEVER prefix these with NEXT_PUBLIC_,
# or the token leaks into the browser bundle. The /api/admin-proxy route reads
# both of these and forwards to the backend with Authorization: Bearer <token>.
ADMIN_API_TOKEN=
BACKEND_API_URL=http://localhost:8000

# HTTP Basic Auth protecting /devs/admin and /api/admin-proxy (see proxy.ts).
# Fail-closed: if either is empty, the admin surface returns 503.
ADMIN_UI_USER=
ADMIN_UI_PASSWORD=

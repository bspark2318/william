# Copy to .env.prod on the Pi at /home/pi/Deployment/william/.env.prod (never commit secrets).

TAVILY_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=

NEWSLETTER_DATABASE_URL=sqlite:////app/data/newsletter.db

# Comma-separated browser origins allowed by CORS (include your public site URL when using Cloudflare).
CORS_ORIGINS=http://localhost:3000

# Cloudflare Tunnel (Zero Trust → Tunnels → your tunnel → copy token)
TUNNEL_TOKEN=

# -----------------------------------------------------------------------------
# /api/devs feed — skill-development feed for agentic coders
# -----------------------------------------------------------------------------

# Apify token for the X (Twitter) scraper. Required for the X source pipeline.
APIFY_TOKEN=

# GitHub PAT (classic or fine-grained, read-only public_repo). Optional.
# Without it, GitHub Search / REST is rate-limited to 60 req/hr; with it, 5000/hr.
GITHUB_TOKEN=

# Feed slot allocation (overrides devs_config.yaml:slot_allocation when set).
DEV_FEED_SIZE_HN=3
DEV_FEED_SIZE_GITHUB=2
DEV_FEED_SIZE_X_TOPICS=3

# Cap on total X handles tracked (protects Apify budget); admin add-handle endpoint
# rejects new handles once this ceiling is reached.
MAX_X_HANDLES=50

# Belt-and-suspenders: rolling 30-day ceiling on tweets ingested via Apify.
APIFY_MONTHLY_TWEET_CAP=15000

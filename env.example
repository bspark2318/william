# Copy to .env.prod on the Pi at /home/pi/Deployment/william/.env.prod (never commit secrets).

TAVILY_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=

NEWSLETTER_DATABASE_URL=sqlite:////app/data/newsletter.db

# Comma-separated browser origins allowed by CORS (include your public site URL when using Cloudflare).
CORS_ORIGINS=http://localhost:3000

# Cloudflare Tunnel (Zero Trust → Tunnels → your tunnel → copy token)
TUNNEL_TOKEN=

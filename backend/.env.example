# Backend environment — copy to .env (or .env.dev) and fill in.

# Shared bearer token that protects /api/admin/*. MUST be set; if empty the
# admin router fails closed (503). Pair with frontend ADMIN_API_TOKEN.
ADMIN_TOKEN=

# External service credentials
TAVILY_API_KEY=
YOUTUBE_API_KEY=
OPENAI_API_KEY=
APIFY_TOKEN=
GITHUB_TOKEN=

# CORS — comma-separated origins allowed to call the backend
CORS_ORIGINS=http://localhost:3000

# Scheduler (UTC hours)
COLLECT_HOUR=6
PUBLISH_HOUR=8
